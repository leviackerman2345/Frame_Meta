# TMDB API Configuration
# Get your token from https://www.themoviedb.org/settings/api
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token_here
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# Debug route guard (keep disabled by default)
ENABLE_DEBUG_ENV_ROUTE=false
DEBUG_ENV_ROUTE_KEY=change_this_to_a_strong_random_secret

# NYT API Configuration (New York Times)
# Get your key from https://developer.nytimes.com/
NYT_API_KEY=your_nyt_api_key_here

# OMDb API Configuration
# Get your key from https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here
